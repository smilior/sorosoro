# =============================================================================
# おうち掃除ログ (sorosoro) — 環境変数テンプレート
# 使い方: cp .env.example .env.local して値を埋める
# 秘密情報は .env.local のみに書く（本ファイルには書かない・コミットしない）
# =============================================================================

# -----------------------------------------------------------------------------
# Database (libSQL / Turso)
# -----------------------------------------------------------------------------
# 【ローカル推奨】別ターミナルで `npm run db:dev` を起動したうえで:
TURSO_DATABASE_URL="http://127.0.0.1:8080"
# drizzle-kit は空文字を拒否するため、ローカルでもダミーを入れる（sqld は検証しない）
TURSO_AUTH_TOKEN="local-dev"

# リモート Turso（Staging / Production）
# TURSO_DATABASE_URL="libsql://xxxx-xxxx.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------
# 秘密鍵: openssl rand -base64 32 で生成
BETTER_AUTH_SECRET=
# アプリの公開 URL（末尾スラッシュなし）
BETTER_AUTH_URL="http://localhost:3000"
# クライアントからも参照する（通常 BETTER_AUTH_URL と同じ）
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google OAuth（GCP / Google Cloud Console）
# https://console.cloud.google.com/ → APIとサービス → 認証情報
#
# 1. OAuth 同意画面を設定（外部 / スコープ: email, profile, openid）
# 2. OAuth クライアント ID 作成（ウェブアプリケーション）
# 3. 承認済みのリダイレクト URI に以下を追加:
#    開発: http://localhost:3000/api/auth/callback/google
#    本番: https://<your-domain>/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV="development"
